// choke mapping helper
static inline int chokeOffsetFromKnob(int knobVal) {
  const int CENTER = 512;
  const int DEADBAND = 80;
  const int MAX_NEG = -55;
  const int MAX_POS = 150;

  // Deadband: center ±80 ADC counts → offset 0ms
  if (knobVal >= CENTER - DEADBAND && knobVal <= CENTER + DEADBAND) {
    return 0;
  }

  // Left of deadband: full CCW → -55ms
  if (knobVal < CENTER - DEADBAND) {
    int lowEnd = CENTER - DEADBAND;  // also the full range [0, lowEnd]
    float blend = float(lowEnd - knobVal) / float(lowEnd);
    return (int)(MAX_NEG * blend);
  }

  // Right of deadband: full CW → +150ms
  int highStart = CENTER + DEADBAND;
  float blend = float(knobVal - highStart) / float(1023 - highStart);
  return (int)(MAX_POS * blend);
}

// D3 effective decay (includes choke and accent boost, capped at 250ms)
static inline float computeD3Decay() {
  float base = d3DecayBase + chokeOffsetMs;
  if (base < 15.0f) base = 15.0f;
  if (d3AccentMode != ACCENT_OFF) base += 7.0f;
  if (base > 250.0f) base = 250.0f;
  return base;
}


// sequence routing
uint8_t* sequenceForTrack(Track t) {
  switch (t) {
    case TRACK_D1: return d1Sequence;
    case TRACK_D2: return d2Sequence;
    case TRACK_D3: return d3Sequence;
    default:       return d1Sequence;  // unreachable — all Track values handled above
  }
}

