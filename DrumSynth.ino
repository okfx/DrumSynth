void sysTickISR() {
  uint32_t now = sysTickMs + 1;
  sysTickMs = now;

  // Aligned 32-bit reads are atomic on ARM Cortex-M7
  if ((uint32_t)(now - lastFrameDrawTick) > OLED_WATCHDOG_TIMEOUT_MS) {
    requestOledReinit = true;
  }
}

