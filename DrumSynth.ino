// Remap a normalized knob value above WF_DEADBAND to 0–1.
// Returns 0 when norm <= deadband, linear 0→1 above it.
static inline float wfActive(float norm) {
  if (norm <= WF_DEADBAND) return 0.0f;
  return (norm - WF_DEADBAND) / (1.0f - WF_DEADBAND);
}

