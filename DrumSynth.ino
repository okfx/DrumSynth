  if (heldMs >= D2_CHROMA_LONG_PRESS_MS) {
    d2ChromaMode = !d2ChromaMode;
    self.enteredMode = true;
    if (d2ChromaMode) {
      selectTrack(TRACK_D2);
    } else {
      d2ChromaHeldStep = -1;
